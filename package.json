{
  "name": "@cloudraker/r2-presign",
  "version": "1.0.0",
  "description": "Presign S3-compatible PUT/GET URLs for Cloudflare R2 (SigV4, zero runtime deps).",
  "keywords": [
    "cloudflare",
    "presign",
    "r2",
    "s3",
    "sigv4"
  ],
  "license": "ISC",
  "author": "CloudRaker",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CloudRaker/r2-presign.git"
  },
  "bugs": {
    "url": "https://github.com/CloudRaker/r2-presign/issues"
  },
  "homepage": "https://github.com/CloudRaker/r2-presign#readme",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run --project unit",
    "test:e2e": "vitest --run --project e2e",
    "test:all": "vitest --run",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.0",
    "aws4fetch": "^1.0.20",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "wrangler": "^4.107.0"
  },
  "packageManager": "pnpm@11.9.0"
}
